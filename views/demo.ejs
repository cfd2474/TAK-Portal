<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Demo</h1>

  <div class="card">
    <p>
      This is a demo page visible only to <strong>Global Admin</strong> users.
    </p>
    <p>
      You can safely use this page for testing UI changes, components, or flows
      without exposing it in the sidebar navigation.
    </p>
  </div>

  <!-- Connected clients card (dashboard-sized, scrollable list) -->
  <div class="card demo-connected-card">
    <h2 class="cardTitle">Connected Clients</h2>
    <div class="connected-clients-wrap">
      <div id="connected-clients-loading" class="connected-clients-msg">Loading…</div>
      <div id="connected-clients-error" class="connected-clients-msg msg bad" style="display:none;"></div>
      <div id="connected-clients-table-wrap" class="connected-clients-table-wrap" style="display:none;">
        <table class="connected-clients-table">
          <thead>
            <tr>
              <th>Callsign</th>
              <th>Username</th>
              <th>TAK Client</th>
              <th>Role</th>
              <th>Team</th>
            </tr>
          </thead>
          <tbody id="connected-clients-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>
</main>

<script>
(function() {
  const tbody = document.getElementById("connected-clients-tbody");
  const loadingEl = document.getElementById("connected-clients-loading");
  const errorEl = document.getElementById("connected-clients-error");
  const tableWrap = document.getElementById("connected-clients-table-wrap");

  function showLoading() {
    loadingEl.style.display = "block";
    errorEl.style.display = "none";
    tableWrap.style.display = "none";
  }
  function showError(msg) {
    loadingEl.style.display = "none";
    errorEl.textContent = msg || "Failed to load connected clients.";
    errorEl.style.display = "block";
    tableWrap.style.display = "none";
  }
  function showTable(rows) {
    loadingEl.style.display = "none";
    errorEl.style.display = "none";
    tableWrap.style.display = "block";
    tbody.innerHTML = "";
    (rows || []).forEach(function(row) {
      const tr = document.createElement("tr");
      tr.innerHTML =
        "<td>" + escapeHtml(row.callsign) + "</td>" +
        "<td>" + escapeHtml(row.username) + "</td>" +
        "<td>" + escapeHtml(row.takClient) + "</td>" +
        "<td>" + escapeHtml(row.role) + "</td>" +
        "<td>" + escapeHtml(row.team) + "</td>";
      tbody.appendChild(tr);
    });
  }
  function escapeHtml(s) {
    if (s == null || s === "") return "";
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  async function load() {
    showLoading();
    try {
      const res = await fetch("/api/tak/subscriptions", { headers: { Accept: "application/json" } });
      const data = await res.json();
      if (!res.ok) {
        showError(data.error || "HTTP " + res.status);
        return;
      }
      if (!data.configured) {
        showError("TAK URL is not configured.");
        return;
      }
      const list = Array.isArray(data.data) ? data.data : [];
      const rows = list.map(function(item) {
        return {
          callsign: item.callsign != null ? String(item.callsign).trim() : "",
          username: item.username != null ? String(item.username).trim() : "",
          takClient: item.takClient != null ? String(item.takClient).trim() || "—" : "—",
          role: item.role != null ? String(item.role).trim() || "—" : "—",
          team: item.team != null ? String(item.team).trim() || "—" : "—"
        };
      });
      showTable(rows);
    } catch (e) {
      showError(e.message || "Network error");
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", load);
  } else {
    load();
  }
})();
</script>

<style>
.demo-connected-card .cardTitle { font-size: 18px; margin: 0 0 10px 0; font-weight: 900; letter-spacing: -0.01em; }
.connected-clients-wrap { min-height: 200px; }
.connected-clients-msg { padding: 12px; color: var(--muted); }
.connected-clients-table-wrap { max-height: 380px; overflow-y: auto; }
.connected-clients-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.connected-clients-table th { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--line); color: var(--muted); font-weight: 600; }
.connected-clients-table td { padding: 8px 12px; border-bottom: 1px solid var(--line); }
.connected-clients-table tbody tr:hover { background: rgba(255,255,255,0.04); }
</style>

