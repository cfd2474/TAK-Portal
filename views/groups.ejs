<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Manage Groups</h1>

  <div class="card">
    <h2>Create Group</h2>

    <div class="row">
      <select id="createType">
        <option value="agency" selected>Agency-Specific Group</option>
        <% if (isGlobalAdmin) { %>
        <option value="county">County-Specific Group</option>
        <option value="generic">Global Group</option>
        <% } %>
      </select>

      <select id="agencyPrefixSelect" style="display:block; width:260px;">
        <option value="">Select Agency</option>
      </select>

      <select id="countySelect" style="display:none; width:260px;">
        <option value="">Select County</option>
      </select>

      <input
        id="groupName"
        placeholder="Group name"
        style="min-width: 210px;"
      />

      <select id="behaviorSelect" style="min-width: 160px;">
        <option value="both">BOTH - Send and Recieve (default)</option>
        <option value="read">READ - Recieve Only</option>
        <option value="write">WRITE - Send Only</option>
      </select>
    </div>

    <div class="row" style="margin-top:8px;">
      <input
        id="groupDescription"
        placeholder="One-line description for this group (optional)"
        style="flex: 1; min-width: 360px;"
      />
    </div>

    <div class="row" style="margin-top:16px; align-items:center;">
      <button class="btn success" id="createBtn" type="button">Create Group</button>
      <span id="createMsg" class="msg"></span>
    </div>

    <p style="margin-top:16px; font-size:0.9rem; color:var(--muted);">
      <strong>Naming rules:</strong> group names must be unique and will be normalized to match existing convention (agency/county prefix and read/write suffix).
    </p>
  </div>

  <div class="card">
    <h2>Groups</h2>

    <div class="row" style="justify-content:space-between; align-items:center;">
      <div class="row" style="gap:8px;">
        <button class="btn" id="reloadBtn" type="button">Reload</button>
        <button class="btn" id="massBtn" type="button">Mass Assign</button>
      </div>
      <div style="font-size:0.9rem; color:var(--muted);">
        Click "Members" to view group membership.
      </div>
    </div>

    <input id="filter" placeholder="Filter groups..." style="margin: 10px 0; min-width: 360px;" />

    <div id="listMsg" class="msg"></div>

    <table class="table">
      <thead>
        <tr>
          <th>Group Name</th>
          <th style="width: 620px;">Actions</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</main>

<!-- Members Modal -->
<div class="modalOverlay" id="membersOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="membersTitle">
    <div class="modalHeader">
      <h2 id="membersTitle" style="margin:0;">Group Members</h2>
      <button class="btn" id="membersCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div id="membersSummary" class="msg"></div>
      <input id="membersFilter" placeholder="Filter members..." style="margin: 10px 0; min-width: 360px;" />
      <div id="membersHint" style="font-size:0.9rem; color:var(--muted); margin-bottom:6px;"></div>
      <div id="membersList" style="max-height:50vh; overflow:auto; border:1px solid var(--border); border-radius:4px; padding:8px; background:var(--bg-subtle);"></div>
    </div>
  </div>
</div>

<!-- Edit Group Modal -->
<div class="modalOverlay" id="editGroupOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="editGroupTitle">
    <div class="modalHeader">
      <h2 id="editGroupTitle" style="margin:0;">Edit Group</h2>
      <button class="btn" id="editGroupCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div class="card" style="margin:0;">
        <h2 style="margin-top:0;">Edit Group</h2>

        <div class="row">
          <!-- Same type dropdown as Create Group -->
          <select id="editType">
            <option value="agency">Agency-Specific Group</option>
            <% if (isGlobalAdmin) { %>
            <option value="county">County-Specific Group</option>
            <option value="generic">Global Group</option>
            <% } %>
          </select>

          <!-- Same agency prefix dropdown -->
          <select id="editAgencyPrefixSelect" style="display:none; width:260px;">
            <option value="">Select Agency</option>
          </select>

          <!-- Same county dropdown -->
          <select id="editCountySelect" style="display:none; width:260px;">
            <option value="">Select County</option>
          </select>

          <!-- Base name (no prefix, no _READ/_WRITE) -->
          <input
            id="editGroupBaseName"
            placeholder="Group name"
            style="min-width: 210px;"
          />

          <!-- Same behavior dropdown -->
          <select id="editBehaviorSelect" style="min-width: 160px;">
            <option value="both">BOTH - Send and Recieve (default)</option>
            <option value="read">READ - Recieve Only</option>
            <option value="write">WRITE - Send Only</option>
          </select>
        </div>

        <div class="row" style="margin-top:8px;">
          <input
            id="editGroupDescription"
            placeholder="One-line description for this group (optional)"
            style="flex: 1; min-width: 360px;"
          />
        </div>

        <div class="row" style="margin-top:16px; align-items:center;">
          <button class="btn success" id="editGroupSaveBtn" type="button">Save Changes</button>
          <span id="editGroupMsg" class="msg"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Mass Assign Modal -->
<div class="modalOverlay" id="massOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="massTitle">
    <div class="modalHeader">
      <h2 id="massTitle" style="margin:0;">Mass Assign</h2>
      <button class="btn" id="massCloseBtn" type="button">Close</button>
    </div>

    <div class="modalBody">
      <div class="segmentControl">
        <button class="segmentControlButton active" data-segment="users">Users</button>
        <button class="segmentControlButton" data-segment="groups">Groups</button>
      </div>

      <div id="massUsersSection">
        <h3>Pick Users</h3>
        <div class="row" style="align-items:center; gap:8px;">
          <input id="massUsersSearchInput" placeholder="Search users..." style="flex:1; min-width: 260px;" />
          <button class="btn" id="massUsersSearchBtn" type="button">Search</button>
        </div>
        <div id="massUsersSearchMsg" class="msg" style="margin-top:8px;"></div>
        <div id="massUsersList" style="margin-top:8px; max-height:260px; overflow:auto; border:1px solid var(--border); border-radius:4px; padding:8px; background:var(--bg-subtle);"></div>
        <div id="massUsersSummary" style="margin-top:8px; font-size:0.9rem; color:var(--muted);"></div>
      </div>

      <div id="massGroupsSection" style="display:none; margin-top:16px;">
        <h3>Pick Groups</h3>
        <div class="row" style="align-items:center; gap:8px;">
          <input id="massGroupsSearchInput" placeholder="Filter groups..." style="flex:1; min-width: 260px;" />
        </div>
        <div id="massGroupsSearchMsg" class="msg" style="margin-top:8px;"></div>
        <div id="massGroupsList" style="margin-top:8px; max-height:260px; overflow:auto; border:1px solid var(--border); border-radius:4px; padding:8px; background:var(--bg-subtle);"></div>
        <div id="massGroupsSummary" style="margin-top:8px; font-size:0.9rem; color:var(--muted);"></div>
      </div>

      <hr style="margin:16px 0;" />

      <div>
        <h3>Action</h3>
        <select id="massActionSelect" style="min-width:240px;">
          <option value="add" selected>Add selected users to selected groups</option>
          <option value="remove">Remove selected users from selected groups</option>
        </select>
      </div>

      <div class="row" style="margin-top:16px; align-items:center;">
        <button class="btn success" id="massApplyBtn" type="button">Apply</button>
        <span id="massMsg" class="msg"></span>
      </div>
    </div>
  </div>
</div>

<script>
const membersOverlay = document.getElementById("membersOverlay");
const membersCloseBtn = document.getElementById("membersCloseBtn");
const membersSummary = document.getElementById("membersSummary");
const membersFilter = document.getElementById("membersFilter");
const membersList = document.getElementById("membersList");
const membersHint = document.getElementById("membersHint");

const createType = document.getElementById("createType");
const agencyPrefixSelect = document.getElementById("agencyPrefixSelect");
const countySelect = document.getElementById("countySelect");
const groupName = document.getElementById("groupName");
const groupDescription = document.getElementById("groupDescription");

// Behavior dropdown
const behaviorSelect = document.getElementById("behaviorSelect");

const createBtn = document.getElementById("createBtn");
const createMsg = document.getElementById("createMsg");

const filter = document.getElementById("filter");
const tbody = document.getElementById("tbody");
const listMsg = document.getElementById("listMsg");
const reloadBtn = document.getElementById("reloadBtn");

// Mass assign elements
const massOverlay = document.getElementById("massOverlay");
const massCloseBtn = document.getElementById("massCloseBtn");
const massBtn = document.getElementById("massBtn");
const massUsersSection = document.getElementById("massUsersSection");
const massGroupsSection = document.getElementById("massGroupsSection");
const massUsersSearchInput = document.getElementById("massUsersSearchInput");
const massUsersSearchBtn = document.getElementById("massUsersSearchBtn");
const massUsersSearchMsg = document.getElementById("massUsersSearchMsg");
const massUsersList = document.getElementById("massUsersList");
const massUsersSummary = document.getElementById("massUsersSummary");
const massGroupsSearchInput = document.getElementById("massGroupsSearchInput");
const massGroupsSearchMsg = document.getElementById("massGroupsSearchMsg");
const massGroupsList = document.getElementById("massGroupsList");
const massGroupsSummary = document.getElementById("massGroupsSummary");
const massActionSelect = document.getElementById("massActionSelect");
const massApplyBtn = document.getElementById("massApplyBtn");
const massMsg = document.getElementById("massMsg");
const massSegmentButtons = document.querySelectorAll(".segmentControlButton");

// Edit Group modal
const editGroupOverlay = document.getElementById("editGroupOverlay");
const editGroupCloseBtn = document.getElementById("editGroupCloseBtn");

const editType = document.getElementById("editType");
const editAgencyPrefixSelect = document.getElementById("editAgencyPrefixSelect");
const editCountySelect = document.getElementById("editCountySelect");
const editGroupBaseNameInput = document.getElementById("editGroupBaseName");
const editBehaviorSelect = document.getElementById("editBehaviorSelect");

const editGroupDescriptionInput = document.getElementById("editGroupDescription");
const editGroupSaveBtn = document.getElementById("editGroupSaveBtn");
const editGroupMsg = document.getElementById("editGroupMsg");

// Show/hide agency / county selects based on type (Edit modal)
if (editType) {
  editType.onchange = () => {
    applyGroupTypeVisibility(editType, editAgencyPrefixSelect, editCountySelect);
  };
}

let editGroupCurrentId = null;
let editGroupCurrentName = "";
let editGroupCurrentDescription = "";

function showEditGroupModal(show){
  editGroupOverlay.style.display = show ? "flex" : "none";
  document.body.classList.toggle("noScroll", !!show);
}

function showMembersModal(show){
  membersOverlay.style.display = show ? "flex" : "none";
  document.body.classList.toggle("noScroll", !!show);
}

membersCloseBtn.onclick = () => showMembersModal(false);

// Simple ministry-of-truth escape
function esc(s){
  return String(s || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
}

function setMsg(el, msg, ok){
  el.textContent = msg || "";
  el.className = msg
    ? ("msg " + (ok === true ? "ok" : ok === false ? "err" : ""))
    : "msg";
}

let agenciesCache = [];
let groupsCache = [];

function applyGroupTypeVisibility(selectEl, agencyEl, countyEl) {
  if (!selectEl || !agencyEl || !countyEl) return;
  const v = selectEl.value;
  const isAgency = v === "agency";
  const isCounty = v === "county";

  agencyEl.style.display = isAgency ? "block" : "none";
  countyEl.style.display = isCounty ? "block" : "none";
}

// Show/hide agency / county selects based on type (Create form)
createType.onchange = () => {
  applyGroupTypeVisibility(createType, agencyPrefixSelect, countySelect);
};

function renderGroups(){
  const needle = String(filter.value || "").trim().toLowerCase();

  const rows = groupsCache
    .filter(g => {
      if(!needle) return true;
      return String(g.name || "").toLowerCase().includes(needle)
        || String(g.pk || "").toLowerCase().includes(needle);
    })
    .map(g => {
      const name = esc(g.name || "");
      const id = String(g.pk || "");
      const description = esc(g.attributes?.description || "");
      const tooltip = description ? ` title="${description}"` : "";

      // Some groups are restricted from destructive actions
      const locked = groupActionsLocked(name);
      const disabledAttr = locked ? " disabled" : "";

      const membersBtn = `<button class="btn" type="button" onclick="viewMembers('${id}')">Members</button>`;
      const renameBtn =
        `<button class="btn" type="button" onclick="editGroupName('${id}')"${disabledAttr}>Rename</button>`;
      const deleteBtn =
        `<button class="btn danger" type="button" onclick="deleteGroup('${id}')"${disabledAttr}>Delete</button>`;

      const lockedNote = locked
        ? `<span style="font-size:0.8rem; color:var(--muted); margin-left:8px;">(Actions locked)</span>`
        : "";

      return `
        <tr>
          <td${tooltip}>${name}</td>
          <td>
            <div class="row" style="gap:8px; align-items:center;">
              ${membersBtn}
              ${renameBtn}
              ${deleteBtn}
              ${lockedNote}
            </div>
          </td>
        </tr>
      `;
    })
    .join("") || `
      <tr>
        <td colspan="2" style="text-align:center; color:var(--muted); padding:12px;">
          No groups found.
        </td>
      </tr>
    `;

  tbody.innerHTML = rows;
}

function groupActionsLocked(groupName){
  // Lock system or global reserved groups if needed
  const name = String(groupName || "").toUpperCase();

  // Example: lock "ADMINS" or any "SYSTEM_..." group
  if(name === "ADMINS") return true;
  if(name.startsWith("SYSTEM_")) return true;

  // Customize more if you need
  return false;
}

async function loadGroups(){
  setMsg(listMsg, "Loading groups...", true);
  try {
    const res = await fetch("/api/groups");
    const out = await res.json();
    if(!res.ok){
      groupsCache = [];
      tbody.innerHTML = `<tr><td colspan="2">Failed to load groups</td></tr>`;
      setMsg(listMsg, out.error || "Failed to load groups", false);
      return;
    }
    groupsCache = Array.isArray(out) ? out : [];
    renderGroups();
    setMsg(listMsg, `Loaded ${groupsCache.length} group(s).`, true);
  } catch(err){
    console.error(err);
    groupsCache = [];
    tbody.innerHTML = `<tr><td colspan="2">Error loading groups</td></tr>`;
    setMsg(listMsg, "Error loading groups", false);
  }
}

filter.oninput = renderGroups;

// Members view
window.viewMembers = async (groupId) => {
  setMsg(membersSummary, "Loading members...", true);
  membersList.innerHTML = "";
  membersFilter.value = "";
  membersHint.textContent = "";

  try {
    const res = await fetch(`/api/groups/${encodeURIComponent(groupId)}/members`);
    const out = await res.json();
    if (!res.ok) {
      setMsg(membersSummary, out.error || "Failed to load group members", false);
      showMembersModal(true);
      return;
    }

    const members = Array.isArray(out) ? out : [];
    membersSummary.textContent = `Found ${members.length} member(s).`;
    membersSummary.className = "msg ok";

    const renderMembers = () => {
      const needle = String(membersFilter.value || "").trim().toLowerCase();
      const rows = members
        .filter(m => {
          if (!needle) return true;
          const display = `${m.username || ""} ${m.displayName || ""} ${m.email || ""}`.toLowerCase();
          return display.includes(needle);
        })
        .map(m => {
          const username = esc(m.username || "");
          const displayName = esc(m.displayName || "");
          const email = esc(m.email || "");
          const roles = Array.isArray(m.roles) ? m.roles.join(", ") : "";

          return `
            <div class="row" style="justify-content:space-between; padding:4px 0; border-bottom:1px solid var(--border-subtle);">
              <div>
                <div><strong>${username || displayName || email}</strong></div>
                <div style="font-size:0.85rem; color:var(--muted);">
                  ${displayName ? esc(displayName) + " · " : ""}${email}
                </div>
              </div>
              <div style="font-size:0.85rem; color:var(--muted);">${esc(roles)}</div>
            </div>
          `;
        })
        .join("") || `<div style="padding:6px; color:var(--muted);">No members match the filter.</div>`;

      membersList.innerHTML = rows;
    };

    membersFilter.oninput = renderMembers;
    membersHint.textContent = "Type in the filter box to search by username, name, or email.";
    renderMembers();
    showMembersModal(true);
  } catch (err) {
    console.error(err);
    setMsg(membersSummary, "Error loading members", false);
    showMembersModal(true);
  }
};

// Load agencies for dropdowns
async function loadAgencies(){
  const res = await fetch("/api/agencies");
  const out = await res.json();
  if(!res.ok){
    agenciesCache = [];
    agencyPrefixSelect.innerHTML = `<option value="">No agencies loaded</option>`;
    countySelect.innerHTML = `<option value="">No counties loaded</option>`;
    return;
  }

  agenciesCache = Array.isArray(out) ? out : [];

  // --- Agency prefix dropdown (groupPrefix) ---
  const prefixList = agenciesCache
    .filter(a => String(a.groupPrefix || "").trim())
    .slice()
    .sort((a,b)=>String(a.name||"").localeCompare(String(b.name||"")));

  agencyPrefixSelect.innerHTML =
    `<option value="">Select Agency</option>` +
    prefixList.map(a => {
      const prefix = String(a.groupPrefix || "").trim().toUpperCase();
      const label = `${a.name || prefix} (${prefix})`;
      return `<option value="${esc(prefix)}">${esc(label)}</option>`;
    }).join("") ||
    `<option value="">No agencies with prefixes</option>`;

  // --- County dropdown ---
  const countySet = new Set(
    agenciesCache
      .map(a => String(a.county || "").trim())
      .filter(c => c)
  );
  const countyList = Array.from(countySet).sort((a, b) => a.localeCompare(b));

  countySelect.innerHTML =
    `<option value="">Select County</option>` +
    countyList.map(c => `<option value="${esc(c)}">${esc(c)}</option>`).join("");

  // Mirror options into Edit modal dropdowns
  if (typeof editAgencyPrefixSelect !== "undefined" && editAgencyPrefixSelect) {
    editAgencyPrefixSelect.innerHTML = agencyPrefixSelect.innerHTML;
  }
  if (typeof editCountySelect !== "undefined" && editCountySelect) {
    editCountySelect.innerHTML = countySelect.innerHTML;
  }

  renderAgencyList();
}

function agencyItems(){
  return agenciesCache
    .filter(a => String(a.suffix || "").trim())
    .slice()
    .sort((a,b)=>String(a.name||"").localeCompare(String(b.name||"")));
}

function renderAgencyList(){
  // (Optional: if you have an agency list somewhere else, render it here.)
}

// --- Create group ---
createBtn.onclick = async () => {
  setMsg(createMsg, "");

  let groupType = String(createType.value || "agency");
  let groupTypeDetail = null;

  let baseName = String(groupName.value || "").trim();
  if(!baseName){
    setMsg(createMsg, "Group name is required.", false);
    return;
  }

  // Behavior suffix
  const behavior = String(behaviorSelect.value || "both").toLowerCase();
  let behaviorSuffix = "";
  if(behavior === "read") behaviorSuffix = "_READ";
  if(behavior === "write") behaviorSuffix = "_WRITE";

  let name = baseName + behaviorSuffix;

  if(groupType === "agency"){
    const prefix = String(agencyPrefixSelect.value || "").trim().toUpperCase();
    if(!prefix){
      setMsg(createMsg, "Select an agency for this group.", false);
      return;
    }
    name = `${prefix} - ${name}`;
    groupTypeDetail = prefix;
  } else if (groupType === "county"){
    const county = String(countySelect.value || "").trim();
    if(!county){
      setMsg(createMsg, "Select a county for this group.", false);
      return;
    }
    name = `${county.toUpperCase()} - ${name}`;
    groupTypeDetail = county;
  } else {
    // generic/global
    groupType = "generic";
    groupTypeDetail = null;
  }

  const description = String(groupDescription.value || "").trim();

  const res = await fetch("/api/groups", {
    method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({
      name,
      description: String(groupDescription.value || "").trim() || null,
      groupType,
      groupTypeDetail,
    })
  });

  const out = await res.json();
  if(!res.ok){
    setMsg(createMsg, out.error || "Create failed", false);
    return;
  }

  setMsg(createMsg, `Created "${name}"`, true);
  groupName.value = "";
  groupDescription.value = "";
  behaviorSelect.value = "both";
  await loadGroups();
};

// Rename helpers
function parseGroupNameForEdit(fullName) {
  let type = "generic";
  let prefix = "";
  let county = "";
  let base = String(fullName || "");
  let behavior = "both";

  const upper = base.toUpperCase();

  // Agency prefixes from agenciesCache
  const agencyPrefixes = (agenciesCache || [])
    .map(a => String(a.groupPrefix || "").trim().toUpperCase())
    .filter(Boolean);

  for (const p of agencyPrefixes) {
    const token = `${p} - `;
    if (upper.startsWith(token)) {
      type = "agency";
      prefix = p;
      base = fullName.slice(token.length); // preserve original casing
      break;
    }
  }

  // If not agency, check counties
  if (type === "generic") {
    const countySet = new Set(
      (agenciesCache || [])
        .map(a => String(a.county || "").trim())
        .filter(Boolean)
    );

    for (const c of countySet) {
      const token = `${c.toUpperCase()} - `;
      if (upper.startsWith(token)) {
        type = "county";
        county = c;
        base = fullName.slice(token.length);
        break;
      }
    }
  }

  // Strip behavior suffix from the remainder
  const baseUpper = base.toUpperCase();
  if (baseUpper.endsWith("_READ")) {
    behavior = "read";
    base = base.slice(0, -5);
  } else if (baseUpper.endsWith("_WRITE")) {
    behavior = "write";
    base = base.slice(0, -6);
  }

  return { type, prefix, county, behavior, baseName: base };
}

// Rename (Edit Name)
window.editGroupName = async (groupId) => {
  setMsg(listMsg, "");

  const g = (groupsCache || []).find(x => String(x.pk) === String(groupId));
  const currentName = String(g?.name || "").trim();
  const currentDescription = String(g?.attributes?.description || "").trim();

  if (!g || !currentName) {
    setMsg(listMsg, "Unable to load group details.", false);
    return;
  }

  if (groupActionsLocked(currentName)) {
    setMsg(listMsg, `Actions are locked for group ${currentName || groupId}`, false);
    return;
  }

  editGroupCurrentId = groupId;
  editGroupCurrentName = currentName;
  editGroupCurrentDescription = currentDescription;

  // Break the name into type/prefix/county/base/behavior
  const parsed = parseGroupNameForEdit(currentName);

  if (editType) {
    editType.value = parsed.type;
    if (editType.onchange) editType.onchange();
  }

  if (editAgencyPrefixSelect) {
    editAgencyPrefixSelect.value = parsed.type === "agency" ? parsed.prefix : "";
  }
  if (editCountySelect) {
    editCountySelect.value = parsed.type === "county" ? parsed.county : "";
  }
  if (editBehaviorSelect) {
    editBehaviorSelect.value = parsed.behavior;
  }
  if (editGroupBaseNameInput) {
    editGroupBaseNameInput.value = parsed.baseName;
  }

  editGroupDescriptionInput.value = currentDescription;

  setMsg(editGroupMsg, "");
  showEditGroupModal(true);
};

// Delete w/ impact
window.deleteGroup = async (groupId) => {
  // Give immediate feedback so the user has context which row this applies to
  const g = (groupsCache || []).find(x => String(x.pk) === String(groupId));
  const currentName = String(g?.name || "").trim();
  if (!currentName) {
    if (!confirm("Delete this group?")) return;
  } else {
    if (!confirm(`Delete group "${currentName}"?`)) return;
  }

  setMsg(listMsg, "Deleting group...", true);

  try {
    const res = await fetch(`/api/groups/${encodeURIComponent(groupId)}`, {
      method: "DELETE"
    });
    const out = await res.json().catch(() => ({}));

    if (!res.ok) {
      setMsg(listMsg, out.error || "Delete failed", false);
      return;
    }
    setMsg(listMsg, `Deleted group "${currentName || groupId}".`, true);
    await loadGroups();
  } catch (err) {
    console.error(err);
    setMsg(listMsg, "Error deleting group", false);
  }
};

editGroupSaveBtn.onclick = async () => {
  setMsg(editGroupMsg, "");

  if (!editGroupCurrentId) {
    setMsg(editGroupMsg, "No group selected.", false);
    return;
  }

  const baseName = String(editGroupBaseNameInput?.value || "").trim();
  const newDescription = String(editGroupDescriptionInput.value || "").trim();

  if (!baseName) {
    setMsg(editGroupMsg, "Group name is required.", false);
    return;
  }

  // Behavior suffix like the Create form
  const behavior = String(editBehaviorSelect?.value || "both").toLowerCase();
  let behaviorSuffix = "";
  if (behavior === "read") behaviorSuffix = "_READ";
  if (behavior === "write") behaviorSuffix = "_WRITE";

  let newName = baseName + behaviorSuffix;

  // Type + prefix/county like the Create form
  const type = String(editType?.value || "agency");

  if (type === "agency") {
    const prefix = String(editAgencyPrefixSelect?.value || "").trim().toUpperCase();
    if (!prefix) {
      setMsg(editGroupMsg, "Select an agency prefix.", false);
      return;
    }
    newName = `${prefix} - ${newName}`;
  } else if (type === "county") {
    const county = String(editCountySelect?.value || "").trim();
    if (!county) {
      setMsg(editGroupMsg, "Select a county.", false);
      return;
    }
    newName = `${county.toUpperCase()} - ${newName}`;
  }
  // type === "generic" just uses base + behavior suffix

  // If nothing actually changed, short-circuit
  if (newName === editGroupCurrentName && newDescription === editGroupCurrentDescription) {
    setMsg(editGroupMsg, "No changes made.", true);
    return;
  }

  if (!confirm(`Save changes to "${editGroupCurrentName}"?`)) return;

  const res = await fetch(`/api/groups/${encodeURIComponent(editGroupCurrentId)}`, {
    method: "PATCH",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      name: newName,
      description: newDescription || null,
    }),
  });

  let out = {};
  try { out = await res.json(); } catch (e) {}

  if (!res.ok) {
    setMsg(editGroupMsg, out.error || "Update failed", false);
    return;
  }

  setMsg(editGroupMsg, `Updated "${editGroupCurrentName}"`, true);
  editGroupCurrentName = newName;
  editGroupCurrentDescription = newDescription;
  await loadGroups();
  showEditGroupModal(false);
};

editGroupCloseBtn.onclick = () => showEditGroupModal(false);

// Mass assign handling
function showMassOverlay(show) {
  massOverlay.style.display = show ? "flex" : "none";
  document.body.classList.toggle("noScroll", !!show);
}

massCloseBtn.onclick = () => showMassOverlay(false);
massBtn.onclick = () => {
  setMsg(massMsg, "");
  setMsg(massUsersSearchMsg, "");
  setMsg(massGroupsSearchMsg, "");
  massUsersSearchInput.value = "";
  massGroupsSearchInput.value = "";
  massUsersList.innerHTML = "";
  massGroupsList.innerHTML = "";
  massUsersSummary.textContent = "";
  massGroupsSummary.textContent = "";
  showMassOverlay(true);
};

// Segment control for Users/Groups
massSegmentButtons.forEach(btn => {
  btn.onclick = () => {
    massSegmentButtons.forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    const segment = btn.getAttribute("data-segment");
    if (segment === "users") {
      massUsersSection.style.display = "block";
      massGroupsSection.style.display = "none";
    } else {
      massUsersSection.style.display = "none";
      massGroupsSection.style.display = "block";
    }
  };
});

// Search users for mass assign
let usersSearchCache = [];

massUsersSearchBtn.onclick = async () => {
  setMsg(massUsersSearchMsg, "Searching users...", true);
  const q = String(massUsersSearchInput.value || "").trim();
  if (!q) {
    setMsg(massUsersSearchMsg, "Enter a search term.", false);
    return;
  }
  try {
    const res = await fetch(`/api/users?q=${encodeURIComponent(q)}`);
    const out = await res.json();
    if (!res.ok) {
      usersSearchCache = [];
      massUsersList.innerHTML = "";
      setMsg(massUsersSearchMsg, out.error || "Failed to search users", false);
      return;
    }
    usersSearchCache = Array.isArray(out) ? out : [];
    renderUserList(usersSearchCache);
    setMsg(massUsersSearchMsg, `Found ${usersSearchCache.length} user(s).`, true);
  } catch (err) {
    console.error(err);
    usersSearchCache = [];
    massUsersList.innerHTML = "";
    setMsg(massUsersSearchMsg, "Error searching users", false);
  }
};

function renderUserList(list) {
  const rows = list.map(u => {
    const username = esc(u.username || "");
    const displayName = esc(u.displayName || "");
    const email = esc(u.email || "");
    const id = String(u.id || u.pk || username);

    return `
      <label class="row" style="align-items:center; gap:8px; padding:4px 0; border-bottom:1px solid var(--border-subtle);">
        <input type="checkbox" class="massUserCheckbox" value="${esc(id)}" />
        <div>
          <div><strong>${username || displayName || email}</strong></div>
          <div style="font-size:0.85rem; color:var(--muted);">${displayName ? displayName + " · " : ""}${email}</div>
        </div>
      </label>
    `;
  }).join("") || `<div style="padding:6px; color:var(--muted);">No users to display.</div>`;

  massUsersList.innerHTML = rows;
  updateMassUsersSummary();
}

function updateMassUsersSummary() {
  const selected = Array.from(document.querySelectorAll(".massUserCheckbox"))
    .filter(cb => cb.checked).length;
  if (!usersSearchCache.length) {
    massUsersSummary.textContent = "";
  } else {
    massUsersSummary.textContent =
      `Showing ${usersSearchCache.length} user(s). ${selected} selected.`;
  }
}

massUsersList.addEventListener("change", (ev) => {
  if (ev.target && ev.target.classList.contains("massUserCheckbox")) {
    updateMassUsersSummary();
  }
});

// Mass groups filter
function renderMassGroups() {
  const needle = String(massGroupsSearchInput.value || "").trim().toLowerCase();
  const rows = (groupsCache || [])
    .filter(g => {
      if (!needle) return true;
      const display = `${g.name || ""} ${g.pk || ""}`.toLowerCase();
      return display.includes(needle);
    })
    .map(g => {
      const name = esc(g.name || "");
      const id = String(g.pk || "");
      return `
        <label class="row" style="align-items:center; gap:8px; padding:4px 0; border-bottom:1px solid var(--border-subtle);">
          <input type="checkbox" class="massGroupCheckbox" value="${esc(id)}" />
          <span>${name}</span>
        </label>
      `;
    })
    .join("") || `<div style="padding:6px; color:var(--muted);">No groups to display.</div>`;

  massGroupsList.innerHTML = rows;
  updateMassGroupsSummary();
}

massGroupsSearchInput.oninput = renderMassGroups;

function updateMassGroupsSummary() {
  const selected = Array.from(document.querySelectorAll(".massGroupCheckbox"))
    .filter(cb => cb.checked).length;
  const total = (groupsCache || []).length;
  if (!total) {
    massGroupsSummary.textContent = "";
  } else {
    massGroupsSummary.textContent =
      `Showing ${total} group(s). ${selected} selected.`;
  }
}

massGroupsList.addEventListener("change", (ev) => {
  if (ev.target && ev.target.classList.contains("massGroupCheckbox")) {
    updateMassGroupsSummary();
  }
});

// Apply mass assignment
massApplyBtn.onclick = async () => {
  setMsg(massMsg, "");

  const selectedUserIds = Array.from(document.querySelectorAll(".massUserCheckbox"))
    .filter(cb => cb.checked)
    .map(cb => cb.value);

  const selectedGroupIds = Array.from(document.querySelectorAll(".massGroupCheckbox"))
    .filter(cb => cb.checked)
    .map(cb => cb.value);

  if (!selectedUserIds.length) {
    setMsg(massMsg, "Select at least one user.", false);
    return;
  }
  if (!selectedGroupIds.length) {
    setMsg(massMsg, "Select at least one group.", false);
    return;
  }

  const massAction = String(massActionSelect.value || "add");
  if (!["add", "remove"].includes(massAction)) {
    setMsg(massMsg, "Invalid action.", false);
    return;
  }

  if (!confirm(`Are you sure you want to ${massAction} ${selectedUserIds.length} user(s) ${massAction === "add" ? "to" : "from"} ${selectedGroupIds.length} group(s)?`)) {
    return;
  }

  setMsg(massMsg, "Applying mass changes...", true);

  try {
    const res = await fetch("/api/groups/mass-assign", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        action: massAction,
        userIds: selectedUserIds,
        groupIds: selectedGroupIds,
      }),
    });

    const out = await res.json().catch(() => ({}));

    if (!res.ok) {
      setMsg(massMsg, out.error || "Mass action failed", false);
      return;
    }

    setMsg(massMsg, `Mass ${massAction} completed successfully.`, true);
    await loadGroups();
  } catch (err) {
    console.error(err);
    setMsg(massMsg, `Mass ${massAction} failed`, false);
  }
};

if (reloadBtn) reloadBtn.onclick = loadGroups;

(async () => {
  createType.onchange();
  await loadAgencies();
  if (typeof editType !== "undefined" && editType) editType.onchange();
  await loadGroups();
})();
</script>

</div></body></html>
