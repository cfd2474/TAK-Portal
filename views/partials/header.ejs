<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<title>TAK Portal</title>
		<link rel="stylesheet" href="/styles.css" />
	</head>
	<body class="theme-<%= brandTheme || 'dark-blue' %>">

		<!-- Mobile menu button (shows under 900px via CSS) -->
		<button
		  class="sidebarToggle"
		  id="sidebarToggle"
		  type="button"
		  aria-controls="sidebar"
		  aria-expanded="false"
>
