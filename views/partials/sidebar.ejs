<%
  const _isGlobalAdmin = typeof isGlobalAdmin !== "undefined" ? !!isGlobalAdmin : false;
  const _isAgencyAdmin = typeof isAgencyAdmin !== "undefined" ? !!isAgencyAdmin : false;

  const isAdmin = _isGlobalAdmin || _isAgencyAdmin;

  // Current user's display name from Authentik (via res.locals.authUser)
  const _displayName =
    typeof authUser !== "undefined" &&
    authUser &&
    authUser.displayName
      ? authUser.displayName
      : "";

  // Only Global Admins can see these
  const canSeeSettings = _isGlobalAdmin;
%>

<aside class="sidebar" id="sidebar">
  <div class="brand <%= brandLogoUrl ? 'has-logo' : 'no-logo' %>">
    <% if (brandLogoUrl) { %>
      <img src="<%= brandLogoUrl %>" alt="Portal logo" class="brand-logo" />
    <% } %>

    <span class="brand-title">TAK Portal</span>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-top">
      <% if (!isAdmin) { %>
        <a href="/setup-my-device">Setup My Device</a>
      <% } else { %>
        <a href="/">Dashboard</a>
        <a href="/users/manage">Users</a>
        <a href="/groups">Groups</a>
        <a href="/templates">Templates</a>

        <% if (canSeeSettings) { %>
          <a href="/agencies">Agencies</a>
          <a href="/mutual-aid">Mutual Aid</a>
          <!-- Pending User Requests moved to banner -->
        <% } %>

        <!--<a href="/qr-generator">QR Code Generator</a>-->
        <a href="/setup-my-device">Setup My Device</a>
      <% } %>
    </div>

    <div class="nav-bottom">
      <a href="/logout" class="logout-link">Log Out</a>

      <% if (canSeeSettings) { %>
        <a href="/settings">Server Settings</a>
      <% } %>

      <small class="version-text">
        <%= _displayName %>
        <% if (_isGlobalAdmin) { %>
          - Global Admin
        <% } else if (_isAgencyAdmin) { %>
          - Agency Admin
        <% } %>
        <br>
        <a
          href="https://github.com/AdventureSeeker423/TAK-Portal/blob/main/CHANGELOG.md"
          target="_blank"
          rel="noopener noreferrer"
        >
          TAK Portal Version <%= APP_VERSION %>
        </a>
      </small>

      <% /* Only admins see the update pill */ %>
      <% if (isAdmin && typeof APP_UPDATE_AVAILABLE !== "undefined" && APP_UPDATE_AVAILABLE) { %>
        <div class="update-available-form">
          <button type="button" class="update-available-pill" id="update-pill">
            Update Available
            <% if (typeof APP_LATEST_VERSION !== "undefined" && APP_LATEST_VERSION) { %>
              &nbsp;(v<%= APP_LATEST_VERSION %>)
            <% } %>
          </button>
        </div>
      <% } %>
    </div>
  </nav>

  <% /* Only admins get the update modal + script */ %>
  <% if (isAdmin && typeof APP_UPDATE_AVAILABLE !== "undefined" && APP_UPDATE_AVAILABLE) { %>
    <div id="update-modal" class="update-modal">
      <div class="update-modal-backdrop update-modal-close"></div>
      <div class="update-modal-dialog">
        <h3 class="update-modal-title">Update Available</h3>

        <p class="update-meta">
          Current: <strong>v<%= APP_VERSION %></strong>
          <% if (typeof APP_LATEST_VERSION !== "undefined" && APP_LATEST_VERSION) { %>
            &nbsp;•&nbsp;Latest: <strong>v<%= APP_LATEST_VERSION %></strong>
          <% } %>
        </p>

        <% if (_isGlobalAdmin) { %>
          <p>
            You can update right from the Web UI. The server will pull the latest code,
            install dependencies, then restart.
          </p>

          <div class="update-actions">
            <button type="button" class="update-primary-btn" id="update-start-btn">
              Update Now
            </button>
            <span class="update-status" id="update-status">Idle</span>
          </div>

          <div class="update-log-wrap">
            <div class="update-log" id="update-log"></div>
          </div>
        <% } else { %>
          <p>Please contact your Global Administrator to update TAK Portal.</p>
        <% } %>

        <p>
          To see what changed, view the
          <a
            href="https://github.com/AdventureSeeker423/TAK-Portal/blob/main/CHANGELOG.md"
            target="_blank"
            rel="noopener noreferrer"
          >
            changelog
          </a>.
        </p>

        <button type="button" class="update-modal-close-btn update-modal-close">
          Close
        </button>
      </div>
    </div>

    <script>
      (function () {
        var pill = document.getElementById('update-pill');
        var modal = document.getElementById('update-modal');
        var startBtn = document.getElementById('update-start-btn');
        var statusEl = document.getElementById('update-status');
        var logEl = document.getElementById('update-log');

        var es = null;
        var isRunning = false;

        if (!pill || !modal) return;

        var closers = modal.querySelectorAll('.update-modal-close');

        function setStatus(text) {
          if (!statusEl) return;
          statusEl.textContent = text;
        }

        function appendLog(line) {
          if (!logEl) return;
          var div = document.createElement('div');
          div.className = 'update-log-line';
          div.textContent = line;
          logEl.appendChild(div);
          logEl.scrollTop = logEl.scrollHeight;
        }

        function connectStream() {
          if (es || !logEl) return;
          es = new EventSource('/api/update/stream');

          es.addEventListener('status', function (ev) {
            try {
              var s = JSON.parse(ev.data || '{}');
              isRunning = !!s.running;
              if (startBtn) startBtn.disabled = isRunning;
              if (isRunning) {
                setStatus('Updating…');
              } else if (s.exitCode === 0 && s.finishedAt) {
                setStatus('Update complete. Restarting…');
              } else if (s.exitCode && s.exitCode !== 0) {
                setStatus('Update failed');
              } else {
                setStatus('Idle');
              }
            } catch (e) {}
          });

          es.addEventListener('log', function (ev) {
            try {
              var entry = JSON.parse(ev.data || '{}');
              var line = entry && entry.line ? entry.line : '';
              if (line) appendLog(line);
            } catch (e) {}
          });

          es.onerror = function () {
            // Connection may drop during restart; that's expected.
            // Keep UI friendly.
            if (isRunning) setStatus('Updating… (connection lost; server may be restarting)');
          };
        }

        function openModal() {
          modal.classList.add('is-open');
          if (logEl) logEl.innerHTML = '';
          setStatus('Idle');
          connectStream();
        }

        function closeModal() {
          modal.classList.remove('is-open');
          if (es) {
            es.close();
            es = null;
          }
        }

        pill.addEventListener('click', openModal);

        closers.forEach(function (el) {
          el.addEventListener('click', function () {
            closeModal();
          });
        });

        if (startBtn) {
          startBtn.addEventListener('click', function () {
            if (startBtn.disabled) return;
            startBtn.disabled = true;
            setStatus('Starting…');
            appendLog('Starting update…');

            fetch('/api/update/start', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({})
            })
              .then(function (r) { return r.json().catch(function () { return {}; }).then(function (j) { return { ok: r.ok, json: j }; }); })
              .then(function (payload) {
                if (!payload.ok) {
                  var msg = (payload.json && (payload.json.error || payload.json.code)) ? (payload.json.error || payload.json.code) : 'Update failed to start';
                  appendLog('ERROR: ' + msg);
                  setStatus('Update failed');
                  startBtn.disabled = false;
                  return;
                }
                setStatus('Updating…');
              })
              .catch(function (err) {
                appendLog('ERROR: ' + (err && err.message ? err.message : String(err)));
                setStatus('Update failed');
                startBtn.disabled = false;
              });
          });
        }
      })();
    </script>
  <% } %>
</aside>
