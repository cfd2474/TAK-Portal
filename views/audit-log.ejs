<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">

  <h1>Audit Log</h1>

  <div class="card">

    <div class="row" style="justify-content: space-between; align-items:center; gap:12px; flex-wrap:wrap;">
      <h2 style="margin:0;">Audit Events</h2>
      <form method="GET" action="/audit-log" class="row" style="gap:8px; flex-wrap:wrap; align-items:center;">

        <input type="text" name="q"
               value="<%= filters?.q || '' %>"
               class="input"
               placeholder="Search..." />

        <input type="text" name="actor"
               value="<%= filters?.actor || '' %>"
               class="input"
               placeholder="Actor" />

        <input type="text" name="action"
               value="<%= filters?.action || '' %>"
               class="input"
               placeholder="Action" />

        <input type="text" name="agencySuffix"
               value="<%= filters?.agencySuffix || '' %>"
               class="input"
               placeholder="Agency" />

        <button class="btn" type="submit">Filter</button>

      </form>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Actor</th>
          <th>Agency</th>
          <th>Action</th>
          <th>Target</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>

        <% if (!result || !result.items || !result.items.length) { %>
          <tr>
            <td colspan="6" class="muted">No audit events found.</td>
          </tr>
        <% } %>

        <% (result?.items || []).forEach(log => { %>
          <tr>
            <td><%= log.timestamp ? new Date(log.timestamp).toLocaleString() : '' %></td>

            <td>
              <strong><%= log.actorDisplayName || log.actorUsername || '-' %></strong><br>
              <span class="muted"><%= log.actorUsername || '' %></span>
            </td>

            <td><%= log.agencySuffix || '-' %></td>

            <td>
              <span class="badge"><%= log.action || '-' %></span>
            </td>

            <td>
              <strong><%= log.targetType || '-' %></strong><br>
              <span class="muted"><%= log.targetId || '' %></span>
            </td>

            <td style="max-width: 400px;">
              <% if (log.details) { %>
                <pre style="margin:0; white-space:pre-wrap; font-size:12px;"><%= JSON.stringify(log.details, null, 2) %></pre>
              <% } %>
            </td>
          </tr>
        <% }) %>

      </tbody>
    </table>

    <!-- Pagination -->
    <% if (result && result.pageCount > 1) { %>
      <div class="pagination">
        <a class="btn" href="<%= pageLinks.prev %>" <%= result.page <= 1 ? 'disabled' : '' %>>Prev</a>

        <span id="pageInfoTop">
          Page <%= result.page %> of <%= result.pageCount %>
        </span>

        <a class="btn" href="<%= pageLinks.next %>" <%= result.page >= result.pageCount ? 'disabled' : '' %>>Next</a>
      </div>
    <% } %>

  </div>

</main>